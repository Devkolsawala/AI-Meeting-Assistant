{
  "name": "meetcopilot",
  "version": "0.0.0",
  "private": true,
  "description": "MeetCopilot — Windows desktop AI meeting assistant (Phase 0 spike).",
  "engines": {
    "node": ">=24.16.0 <25",
    "pnpm": ">=11.5.0 <12"
  },
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yaml,yml}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "volta": {
    "node": "24.16.0"
  }
}
