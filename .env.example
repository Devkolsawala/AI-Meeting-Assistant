# MeetCopilot environment variables.
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# These keys are used SERVER-SIDE only (apps/api). They must never reach the
# desktop renderer — the client only ever receives short-lived tokens.

# Deepgram (speech-to-text) — https://console.deepgram.com
DEEPGRAM_API_KEY=

# ElevenLabs (speech-to-text) — https://elevenlabs.io
ELEVENLABS_API_KEY=

# Sarvam (speech-to-text) — https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Active speech-to-text provider for the desktop app: deepgram | elevenlabs | sarvam.
# This is NOT a secret — it selects which adapter the renderer uses. Read by the
# desktop process from the shell environment (see README). Defaults to deepgram.
# STT_PROVIDER=deepgram

# --- Supabase (Project Settings -> Data API / API Keys) ---
# URL and anon/publishable key are PUBLIC (safe in web + desktop clients).
# The desktop app reads SUPABASE_URL + SUPABASE_ANON_KEY to run the PKCE login.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Where the Next.js web app (login pages) is reachable. Desktop opens this in the
# browser to start sign-in. Defaults to http://localhost:3000 when unset.
WEB_URL=http://localhost:3000

# Backend API base the desktop app calls for /infer and /stt-token.
# Defaults to http://127.0.0.1:8787 when unset.
API_URL=http://127.0.0.1:8787
# Service-role key and JWT secret are SERVER-SIDE ONLY (apps/api). NEVER ship these
# to any client. The backend uses the service role to write billing/usage rows
# (which bypasses RLS) and the JWT secret to validate user tokens.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- AWS Bedrock (SERVER-SIDE ONLY; region near the backend) ---
# Credentials come from the standard AWS provider chain (env vars below, or an
# instance/role on App Runner). NEVER ship these to any client.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional Bedrock model overrides (sensible defaults are chosen in code).
# Fast lane = Nova/Haiku; smart lane = Sonnet. Enable model access in Bedrock first.
# BEDROCK_FAST_MODEL_ID=amazon.nova-lite-v1:0
# BEDROCK_SMART_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# --- Free-plan caps (SERVER-SIDE plan gating; not secrets) ---
# Free users are blocked at EITHER cap. A paid plan raises these (Milestone 4).
# Defaults: 2 sessions, 180 seconds (~3 minutes), warn at 80%.
# FREE_MAX_SESSIONS=2
# FREE_MAX_STT_SECONDS=180
# USAGE_WARN_RATIO=0.8

# --- Observability (optional; each is a no-op when unset) ---
# Sentry DSNs — separate projects for the backend and the desktop app. DSNs are
# not secret (they're embeddable in clients), but keep them in env, not code.
# SENTRY_DSN_API=
# SENTRY_DSN_DESKTOP=
# PostHog product analytics. The project API key is write-only/ingest-safe.
# POSTHOG_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
# Langfuse LLM tracing (per-call cost + latency) — used by apps/api only.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASEURL=https://cloud.langfuse.com
