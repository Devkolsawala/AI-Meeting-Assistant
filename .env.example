# MeetCopilot environment variables.
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# These keys are used SERVER-SIDE only (apps/api). They must never reach the
# desktop renderer — the client only ever receives short-lived tokens.

# Deepgram (speech-to-text) — https://console.deepgram.com
DEEPGRAM_API_KEY=

# ElevenLabs (speech-to-text) — https://elevenlabs.io
ELEVENLABS_API_KEY=

# Sarvam (speech-to-text) — https://dashboard.sarvam.ai
SARVAM_API_KEY=
