# Public Supabase config for the web auth pages. Copy this file to
# apps/web/.env.local and fill in real values. These are PUBLIC (safe in the
# browser); never put the service-role key or JWT secret here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. The /download route 302-redirects here (e.g. a GitHub Releases
# asset or S3 URL). Leave it unset and the download buttons open a "notify me"
# waitlist instead. NOT prefixed with NEXT_PUBLIC: the URL never ships to the
# client. Changing it takes effect immediately for /download; the home page's
# button state is baked at build time, so redeploy after toggling it.
INSTALLER_DOWNLOAD_URL=
