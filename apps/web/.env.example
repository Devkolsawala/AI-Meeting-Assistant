# Public Supabase config for the web auth pages. Copy this file to
# apps/web/.env.local and fill in real values. These are PUBLIC (safe in the
# browser); never put the service-role key or JWT secret here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. The /download route 302-redirects here. Point it at the latest
# signed GitHub release asset (stable, version-less name from electron-builder):
#   https://github.com/Devkolsawala/AI-Meeting-Assistant/releases/latest/download/MeetCopilot-Setup.exe
# Leave it unset and the download buttons open a "notify me" waitlist instead.
# NOT prefixed with NEXT_PUBLIC: the URL never ships to the client. Changing it
# takes effect immediately for /download; the home page's button state is baked at
# build time, so redeploy after toggling it.
INSTALLER_DOWNLOAD_URL=

# Public base URL of the backend API (AWS App Runner). Reserved for Phase 2 —
# the web app does not call it yet (/account reads the plan straight from
# Supabase via RLS). Documented here so the Vercel env is ready when the
# account page starts calling the backend. Safe in the browser (no secret).
NEXT_PUBLIC_API_BASE_URL=

# --- Billing (Razorpay) — SERVER-ONLY secrets. Used by /api/checkout and the
# --- /api/razorpay/webhook route. Never prefix these with NEXT_PUBLIC.
# Service-role key: the webhook is the ONLY writer of subscription status, and
# writing bypasses RLS. Keep this secret; never ship it to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Razorpay API key pair (Dashboard → Settings → API Keys). The key id is returned
# to the browser by /api/checkout; the secret never leaves the server.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret (Dashboard → Settings → Webhooks). Verifies deliveries.
RAZORPAY_WEBHOOK_SECRET=
# The Razorpay Plan id for the paid tier (Dashboard → Subscriptions → Plans).
RAZORPAY_PLAN_ID=
# Plan name written to subscriptions.plan when active (default "pro").
# RAZORPAY_PLAN_NAME=pro
# Number of billing cycles for a new subscription (default 120 = 10 years monthly).
# RAZORPAY_SUBSCRIPTION_TOTAL_COUNT=120

# --- Observability (optional; each is a no-op when unset) ---
# Sentry — server-side (route handlers) and client-side (browser). The DSN is not
# secret; the NEXT_PUBLIC_ copy is inlined into the browser bundle.
# SENTRY_DSN_WEB=
# NEXT_PUBLIC_SENTRY_DSN_WEB=
# PostHog — server-side events (download, upgrade) and client-side (signed_in).
# The project API key is write-only/ingest-safe, so a NEXT_PUBLIC_ copy is fine.
# POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
